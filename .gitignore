# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 知识页配图历史版本(本地对比用,不入仓)
/.knowledge-wanx-backup/

# next-pwa 自动生成的 service worker(每次 build 重新生成,无需入仓)
/public/sw.js
/public/workbox-*.js
/public/worker-*.js
/public/fallback-*.js
